generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  RESTAURANT_ADMIN
  RIDER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  name        String?
  phone       String?  @unique
  email       String?  @unique
  role        Role     @default(CUSTOMER)
  address     String?
  orders      Order[]
  addresses   Address[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Address {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  street    String
  city      String
  state     String
  zipCode   String
  lat       Float?   
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id            String     @id @default(uuid())
  name          String
  address       String
  lat           Float?     // Added for Location & Radius API
  lng           Float?     // Added for Location & Radius API
  rating        Float      @default(0.0)
  openingHours  String
  isPureVeg     Boolean    @default(false) // Added for Common Filters
  costForTwo    Int?       // Added for Common Filters
  cuisines      String[]   // Added for Common Filters (e.g., ["North Indian", "Chinese"])
  imageUrl      String?    // Added for Restaurant Banners
  menuItems     MenuItem[]
  orders        Order[]
  adminId       String     
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model MenuItem {
  id           String      @id @default(uuid())
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  restaurantId String
  name         String
  price        Float
  category     String
  isVeg        Boolean     @default(true) 
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
}

model DeliveryPartner {
  id           String   @id @default(uuid())
  userId       String   @unique 
  vehicleType  String
  locationLat  Float?
  locationLng  Float?
  availability Boolean  @default(false)
  orders       Order[]
  createdAt    DateTime @default(now())
}

model Order {
  id                String           @id @default(uuid())
  user              User             @relation(fields: [userId], references: [id])
  userId            String           
  restaurant        Restaurant       @relation(fields: [restaurantId], references: [id])
  restaurantId      String
  deliveryPartner   DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  deliveryPartnerId String?
  status            OrderStatus      @default(PENDING)
  totalAmount       Float            
  deliveryAddress   String           
  items             OrderItem[]      
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model OrderItem {
  id                 String   @id @default(uuid())
  order              Order    @relation(fields: [orderId], references: [id])
  orderId            String
  menuItem           MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId         String
  quantity           Int
  priceAtTimeOfOrder Float    
}

model Banner {
  id        String   @id @default(uuid())
  bannerName      String @default("veg-banner")
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}